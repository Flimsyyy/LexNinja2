{
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0r.char": "Shake hands, shake both hands.",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0r.next": "Continue",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1r.ancient": "Where did you come from?",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1r.next": "Unleash",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2r.char": "[jitter]You startled me, I unleash Ninjutsu![/jitter]",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-attack": "Both",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "Are you done yet?",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.next": "Answer",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-1r.char": "You're the one who insists on making my life miserable.",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-attack": "Both",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0r.ancient": "How long are you going to keep playing here?",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0r.next": "Answer",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1r.char": "Architect, you'd better leave now.\n[jitter]Otherwise, I'll annihilate your grandma grandpa![/jitter]",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1r.next": "Continue",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2r.ancient": "Amused despite my anger.",
  "THE_ARCHITECT.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-attack": "Both",

  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.ancient": "What brings you here?\nStill tangled up with that Ha-something?",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Answer",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.char": "Hamood Hamood is very tired.",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.next": "Continue",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2.ancient": "So things settled down after you left the Spire last time.",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "Oh, it's you. I still have that peashooter you grew.\nCome claim it when it recognizes you.",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.ancient": "You're back again. Want something shiny?",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Answer",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.char": "Can't bear to part with money.",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.next": "Continue",
  "DARV.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2.ancient": "[sine]Oh, bartering works too~[/sine]",
  
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.ancient": "[sine]..You...came too...\n ...half-bodied... ...ninja....[/sine]",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Talk",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.char": "All come back, all come, all come back!",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.next": "Continue",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2.ancient": "[i][font_size=22]<You can't tell if Neow is happy or asleep>[/font_size][/i]",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "[sine]...I...brought you...back.. ..[/sine]",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.char": "Wailing, wailing!\n[jitter]I didn't do anything![/jitter]",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Continue",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.ancient": "[sine]...Take...this... ..go...[/sine]",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.next": "Thanks",
  "NEOW.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2.char": "Eh, I'm not in pain anymore, [sine]I'm so happy now~~[/sine]",

  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.char": "[jitter]Ah, it seems, ah, it seems like a beastman is attacking![/jitter]",
  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Continue",
  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.ancient": "How rude! But you look strong.\nMasked hero, take my blessing and hunt the madness!",
  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "The hooded half-bodied little yellow person has returned.\nPick a gift and go!",
  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.ancient": "[i][font_size=22]<Describing the Architect's erratic behavior with vivid expression>[/font_size][/i]",
  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "React",
  "NONUPEIPE.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.char": "Furious! So~~ furious!",

  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.ancient": "Hooded guy? Where from?\nOnly half a body? How interesting!!",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Demonstrate",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.char": "The perfect body!",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.next": "Continue",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2.ancient": "Ninjutsu! So fun! Do another, do another!",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "Little ninja! I want to see Ninjutsu!\nI have good stuff, so do more!!",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.char": "Ah~~~ [jitter]thirsty thirsty thirsty thirsty thirsty~~[/jitter]\nAh~~~",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Continue",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.ancient": "Drink! Here's a Xiang Piao Piao Hot Drink for you!",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.next": "Drink",
  "OROBAS.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2.char": "Good water, drank enough.\n[sine]Glug glug glug glug~[/sine]",

  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.char": "A Nailoong.",
  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Continue",
  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.ancient": "[thinky_dots]Whatever you say...\ntake a piece from me for your journey...[/thinky_dots]",
  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "[thinky_dots]Little black thing...\ndon't disturb my sleep...[/thinky_dots]",
  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.char": "Sleep well, Sleep well.",
  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Continue",
  "PAEL.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.ancient": "[thinky_dots]zZZzz...[/thinky_dots]",

  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.ancient": "[b]Black?! Half-bodied person?!\nCarrying a blade too?![/b]",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Respond",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.char": "Shake hands, good hero.",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.next": "Continue",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2.ancient": "[b]Interesting! Take this!!![/b]",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "[b]Ninja! Show me your Ninjutsu!!![/b]",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.ancient": "[b]Lex Ninja, fight me!![/b]",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Fight",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.char": "[i][font_size=22]Surely everyone with ninja dynamic vision has already watched this exhilarating karate bout.[/font_size][/i]",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.next": "Continue",
  "TANX.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2.ancient": "[b]What a perfect body!![/b]",

  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.ancient": "Ohoho, what a rare guest! Hello there, little one~",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Respond",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.char": "Shake hands, shake both hands.",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.next": "Continue",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2.ancient": "What a polite little one.\n[i][font_size=22]Tezcatara giggles happily.[/font_size][/i]",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "The little black one is back?\nLet me light your flame [jitter][b]a bit brighter[/b][/jitter]!!!",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.ancient": "Welcome back, little ninja! Have you made the Spire [jitter][b]brighter[/b][/jitter]?",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Respond",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.char": "Ah grandma, ah grandma! (crying voice)",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.next": "Continue",
  "TEZCATARA.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2.ancient": "Oh dear, don't worry, you can do it.",

  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.ancient": "Oh? The killer of the Elder Gods is back too? This time alone?",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-0.next": "Chat",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.char": "[jitter][b]Vakuu, you'd better leave now, or I'll annihilate your grandma grandpa!!![/b][/jitter]",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-1.next": "Continue",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.0-2.ancient": "Calm down, I'm not here to harm you.",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.1-0r.ancient": "It's not pleasant being constantly harassed by that guy, is it? I can help you get a break for a while~",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.ancient": "Just sign this, let me take over for a bit. I guarantee you won't regret it.",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-0.next": "Angry",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.char": "Furious.\n[jitter][b]So~~ furious!![/b][/jitter]",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-1.next": "Continue",
  "VAKUU.talk.LEX_NINJA2_CHARACTER_LEX_NINJA2.2-2.ancient": "You can't do anything about me.\nWhy not compromise? It's better for everyone."
}